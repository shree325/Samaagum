  target_id   String   @db.Uuid
  target_type String   @db.VarChar(10)
  emoji       String   @db.VarChar(10)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  users       users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, target_id, target_type, emoji])
  @@index([target_id, target_type], map: "idx_forum_reactions_target")
}

model forum_tags {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String            @db.Uuid
  scope_id        String            @db.Uuid
  scope_type      String            @default("group") @db.VarChar(20)
  name            String            @db.VarChar(50)
  color           String            @default("gray") @db.VarChar(20)
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  forum_post_tags forum_post_tags[]

  @@unique([scope_id, name])
  @@index([scope_id], map: "idx_forum_tags_scope")
}

model forum_votes {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  user_id     String   @db.Uuid
  target_id   String   @db.Uuid
  target_type String   @db.VarChar(10)
  vote        Int      @db.SmallInt
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  users       users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, target_id, target_type])
  @@index([target_id, target_type], map: "idx_forum_votes_target")
}

model group_gallery {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String   @db.Uuid
  group_id         String   @db.Uuid
  uploader_user_id String   @db.Uuid
  url              String
  type             String   @default("image") @db.VarChar(10)
  status           String   @default("approved") @db.VarChar(20)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  users            users    @relation(fields: [uploader_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([group_id], map: "idx_group_gallery_group")
}

model group_invitations {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  group_id     String    @db.Uuid
  email        String?
  username     String?
  token        String    @unique
  status       String    @default("pending")
  link_type    String    @default("single_use")
  max_uses     Int?
  uses_count   Int       @default(0)
  expires_at   DateTime? @db.Timestamptz(6)
  accepted_at  DateTime? @db.Timestamptz(6)
  invited_by   String?   @db.Uuid
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @db.Timestamptz(6)
  email_status String?   @default("pending") @db.VarChar(50)
  groups       groups    @relation(fields: [group_id], references: [entity_id], onDelete: Cascade)
  users        users?    @relation(fields: [invited_by], references: [id])
}

model messaging_requests {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sender_id   String   @db.Uuid
  receiver_id String   @db.Uuid
  status      String   @default("PENDING")
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
  receiver    users    @relation("received_messaging_requests", fields: [receiver_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sender      users    @relation("sent_messaging_requests", fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([sender_id, receiver_id])
}

model event_registration_log {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id   String   @db.Uuid
  changed_by String   @db.Uuid
  action     String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [changed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  events     events   @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model event_wishlist {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id   String   @db.Uuid
  user_id    String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  events     events   @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([event_id, user_id])
  @@index([event_id], map: "idx_event_wishlist_event")
  @@index([user_id], map: "idx_event_wishlist_user")
}

