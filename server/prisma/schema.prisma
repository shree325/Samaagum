model admin_subscription_plans {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String                @unique
  display_name        String
  description         String?
  category            String                @default("individual")
  plan_type           String                @default("monthly")
  is_active           Boolean               @default(true)
  is_popular          Boolean               @default(false)
  group_name          String?
  pricing             Json                  @default("{}")
  features            Json                  @default("[]")
  limits              Json                  @default("[]")
  metadata            Json                  @default("{}")
  trial               Json?
  visibility          Json                  @default("{}")
  rbac_role_id        String?               @db.Uuid
  rbac_position_id    String?               @db.Uuid
  rbac_auto_assign    Boolean               @default(false)
  tenant_id           String?               @db.Uuid
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @default(now()) @db.Timestamptz(6)
  admin_positions     admin_positions?      @relation(fields: [rbac_position_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  admin_roles         admin_roles?          @relation(fields: [rbac_role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenants             tenants?              @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subscription_orders subscription_orders[]

  @@index([is_active], map: "idx_admin_plans_active")
  @@index([tenant_id], map: "idx_admin_plans_tenant")
}

model admin_coupons {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                String
  description         String?
  discount_type       String    @default("percent")
  amount              Decimal   @default(0) @db.Decimal(10, 2)
  date_expires        DateTime? @db.Timestamptz(6)
  usage_count         Int       @default(0)
  is_active           Boolean   @default(true)
  free_shipping       Boolean   @default(false)
  usage_restrictions  Json      @default("{}")
  usage_limits        Json      @default("{}")
  email_settings      Json      @default("{}")
  applicable_plan_ids Json      @default("[]")
  meta_data           Json      @default("[]")
  tenant_id           String?   @db.Uuid
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  updated_at          DateTime  @default(now()) @db.Timestamptz(6)
  tenants             tenants?  @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([code, tenant_id])
  @@index([code], map: "idx_admin_coupons_code")
  @@index([is_active, date_expires], map: "idx_admin_coupons_active")
  @@index([tenant_id], map: "idx_admin_coupons_tenant")
}

model subscription_orders {
  id                       String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_number             String                   @unique
  user_id                  String                   @db.Uuid
  tenant_id                String?                  @db.Uuid
  status                   String                   @default("pending")
  plan_id                  String                   @db.Uuid
  plan_type                String
  shipping_address         Json                     @default("{}")
  billing_address          Json                     @default("{}")
  subtotal                 Decimal                  @default(0) @db.Decimal(10, 2)
  tax_total                Decimal                  @default(0) @db.Decimal(10, 2)
  total                    Decimal                  @default(0) @db.Decimal(10, 2)
  currency                 String                   @default("INR")
  taxes                    Json                     @default("[]")
  coupon_code              String?
  discount_amount          Decimal                  @default(0) @db.Decimal(10, 2)
  payment_method           String
  payment_method_title     String
  payment_transaction_id   String?
  payment_intent_id        String?
  payment_status           String                   @default("pending")
  payment_paid_date        DateTime?                @db.Timestamptz(6)
  payment_gateway_response Json                     @default("{}")
  subscription_start_date  DateTime?                @db.Timestamptz(6)
  subscription_end_date    DateTime?                @db.Timestamptz(6)
  subscription_status      String                   @default("pending")
  customer_note            String?
  admin_notes              Json                     @default("[]")
  metadata                 Json                     @default("{}")
  completed_at             DateTime?                @db.Timestamptz(6)
  created_at               DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at               DateTime                 @default(now()) @db.Timestamptz(6)
  admin_subscription_plans admin_subscription_plans @relation(fields: [plan_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenants                  tenants?                 @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                    users                    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([status], map: "idx_sub_orders_status")
  @@index([tenant_id], map: "idx_sub_orders_tenant")
  @@index([user_id], map: "idx_sub_orders_user")
}

