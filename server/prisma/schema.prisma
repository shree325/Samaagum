  longitude        Decimal? @db.Decimal(10, 6)
  timezone         String?  @db.VarChar(100)

  @@index([city_name], map: "idx_city_controls_city_name")
  @@index([country_name], map: "idx_city_controls_country_name")
  @@index([is_active], map: "idx_city_controls_is_active")
  @@index([city_name, state_name, country_name], map: "idx_city_controls_search")
  @@index([state_name], map: "idx_city_controls_state_name")
}

