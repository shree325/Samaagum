{
  "name": "samaagum-monorepo",
  "version": "1.0.0",
  "description": "Samaagum Full-Stack Monorepo",
  "scripts": {
    "generate:api": "npx openapi-typescript shared/openapi/admin.yaml -o client/src/generated/api-types.ts",
    "generate:api:watch": "npx openapi-typescript shared/openapi/admin.yaml -o client/src/generated/api-types.ts --watch",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0"
  }
}
